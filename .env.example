# bookMaker Environment Variables
# Bu dosyayi .env olarak kopyalayip kendi degerlerinizi girin
# .env dosyasi ASLA git'e commit EDILMEZ (.gitignore'da var)

# LLM API Yapilandirmasi
BOOKMAKER_LLM_API_KEY=YOUR_DEEPSEEK_API_KEY_HERE
BOOKMAKER_LLM_MODEL=deepseek-chat
BOOKMAKER_LLM_BASE_URL=https://api.deepseek.com/v1
BOOKMAKER_LLM_TIMEOUT=300
BOOKMAKER_LLM_MAX_RETRIES=3
BOOKMAKER_LLM_MAX_TOKENS=8192
BOOKMAKER_LLM_TEMPERATURE=0.7

# Studio GUI
BOOKMAKER_STUDIO_PORT=8765
BOOKMAKER_STUDIO_HOST=127.0.0.1
# BOOKMAKER_STUDIO_TOKEN=my-secret-token

# Logging
BOOKMAKER_LOG_LEVEL=INFO

# Pipeline
BOOKMAKER_MAX_WORKERS=4

# Kod Uretimi
BOOKMAKER_CODE_TIMEOUT=30
BOOKMAKER_CODE_MAX_LINES=1000

# Mermaid
BOOKMAKER_MERMAID_TIMEOUT=30
