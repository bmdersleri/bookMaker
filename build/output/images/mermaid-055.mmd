classDiagram
    class Kitap {
        -String ISBN
        -String baslik
        -String yazar
        -boolean oduncAlindi
        +kitapEkle()
        +kitapSil()
        +kitapGuncelle()
    }
    
    class Uye {
        -int uyeNo
        -String ad
        -String soyad
        -ArrayList~Kitap~ oduncKitaplar
        +kitapOduncAl(Kitap)
        +kitapIadeEt(Kitap)
    }
    
    class Kutuphane {
        -ArrayList~Kitap~ kitaplar
        -ArrayList~Uye~ uyeler
        +kitapAra(String)
        +uyeEkle(Uye)
        +raporOlustur()
    }
    
    Kutuphane "1" --> "*" Kitap
    Kutuphane "1" --> "*" Uye
    Uye --> Kitap : odunc alir