{
  "statusLine": {
    "type": "command",
    "command": "sh 'D:/bookMaker_clean/.claude/statusline-command.sh'"
  },
  "hooks": {
    "SessionStart": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "sh 'D:/bookMaker_clean/.claude/hooks/session-start.sh'"
          }
        ]
      }
    ],
    "Stop": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "sh 'D:/bookMaker_clean/.claude/hooks/session-stop.sh'"
          }
        ]
      }
    ],
    "PreToolUse": [
      {
        "matcher": "Bash",
        "hooks": [
          {
            "type": "command",
            "command": "sh 'D:/bookMaker_clean/.claude/hooks/pre-commit-validate.sh'"
          }
        ]
      }
    ]
  }
}
